# Flick local environment contract.
# Copy values into .env.local and keep .env.local untracked.

FLICK_ENV=development
FLICK_LOG_LEVEL=debug

# Public web/API URLs.
FLICK_PUBLIC_BASE_URL=http://localhost:5173
PUBLIC_FLICK_API_BASE_URL=http://localhost:8080
PUBLIC_FLICK_LOCAL_FILE_MAX_BYTES=1048560
FLICK_API_BASE_URL=http://localhost:8080
FLICK_INTERNAL_API_BASE_URL=http://localhost:8080
FLICK_API_ADDR=:8080

# Internal auth for worker -> api calls. Set a strong local value.
FLICK_INTERNAL_TOKEN=change-me-local

# NATS JetStream.
FLICK_NATS_URL=nats://127.0.0.1:4222
FLICK_NATS_STREAM=FLICK_JOBS
FLICK_NATS_JOB_SUBJECT=flick.jobs

# Local SQLite files.
FLICK_DATA_DIR=./var
FLICK_API_DB_PATH=./var/api.db
FLICK_WORKER_DB_PATH=./var/worker.db

# Storage thresholds.
FLICK_PAYLOAD_INLINE_MAX_BYTES=1048576
FLICK_MAX_FILE_BYTES=26214400
FLICK_DEFAULT_TTL_SECONDS=3600
FLICK_MIN_TTL_SECONDS=300
FLICK_MAX_TTL_SECONDS=604800
FLICK_STORAGE_LARGE_BACKEND=disabled
FLICK_OPEN_RATE_PER_MIN=10
# Trusted proxy CIDRs (comma-separated) whose peer may set X-Forwarded-For. Empty = direct peer IP only.
FLICK_TRUSTED_PROXIES=

# Worker.
FLICK_WORKER_ID=local-worker-1
FLICK_WORKER_CONCURRENCY=2

# OCI Object Storage. Used only when FLICK_STORAGE_LARGE_BACKEND=oci.
FLICK_OCI_AUTH_MODE=config_file
FLICK_OCI_CONFIG_FILE=
FLICK_OCI_PROFILE=DEFAULT
FLICK_OCI_REGION=
FLICK_OCI_NAMESPACE=
FLICK_OCI_BUCKET=
FLICK_OCI_COMPARTMENT_OCID=

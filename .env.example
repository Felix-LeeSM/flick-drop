# Flick local environment contract.
# Copy values into .env.local and keep .env.local untracked.

FLICK_ENV=development
FLICK_LOG_LEVEL=debug
# json (default, production) or text (local dev readability).
FLICK_LOG_FORMAT=text

# Public web/API URLs.
FLICK_PUBLIC_BASE_URL=http://localhost:5173
PUBLIC_FLICK_API_BASE_URL=http://localhost:8080
# Build-time mirrors of the server TTL config (defaults match internal/config/defaults.go;
# scripts/ci/ttl-drift.sh enforces the match).
PUBLIC_FLICK_MIN_TTL_SECONDS=300
PUBLIC_FLICK_MAX_TTL_SECONDS=604800
PUBLIC_FLICK_DEFAULT_TTL_SECONDS=3600
FLICK_API_BASE_URL=http://localhost:8080
FLICK_INTERNAL_API_BASE_URL=http://localhost:8080
FLICK_API_ADDR=:8080

# Internal auth for worker -> api calls. Set a strong local value.
FLICK_INTERNAL_TOKEN=change-me-local
# Bearer token guarding /metrics (Prometheus scrape). Separate from the internal token.
FLICK_METRICS_TOKEN=change-me-metrics-local

# NATS JetStream.
FLICK_NATS_URL=nats://127.0.0.1:4222
FLICK_NATS_STREAM=FLICK_JOBS
FLICK_NATS_JOB_SUBJECT=flick.jobs

# Local SQLite files.
FLICK_DATA_DIR=./var
FLICK_API_DB_PATH=./var/api.db
FLICK_WORKER_DB_PATH=./var/worker.db

# Storage thresholds.
FLICK_PAYLOAD_INLINE_MAX_BYTES=1048576
FLICK_MAX_FILE_BYTES=52428800
FLICK_DEFAULT_TTL_SECONDS=3600
FLICK_MIN_TTL_SECONDS=300
FLICK_MAX_TTL_SECONDS=604800
FLICK_STORAGE_LARGE_BACKEND=disabled
FLICK_OPEN_RATE_PER_MIN=10
FLICK_CREATE_RATE_PER_MIN=5
# Expiration reaper: sweep expired/orphan secrets out of api.db.
FLICK_REAPER_INTERVAL_SECONDS=60
FLICK_REAPER_BATCH_SIZE=50
# Trusted proxy CIDRs (comma-separated) whose peer may set X-Forwarded-For. Empty = direct peer IP only.
FLICK_TRUSTED_PROXIES=

# Worker.
FLICK_WORKER_ID=local-worker-1
FLICK_WORKER_CONCURRENCY=2

# S3-compatible object storage. Used only when FLICK_STORAGE_LARGE_BACKEND=s3.
# MinIO (dev) or OCI S3-compatible (prod). Auth is a static key pair.
FLICK_S3_ENDPOINT=http://localhost:9000
FLICK_S3_REGION=us-east-1
FLICK_S3_BUCKET=flick-dev
FLICK_S3_ACCESS_KEY_ID=minioadmin
FLICK_S3_SECRET_ACCESS_KEY=minioadmin
FLICK_S3_PATH_STYLE=true

# BurnLink local environment contract.
# Copy values into .env.local and keep .env.local untracked.

BURNLINK_ENV=development
BURNLINK_LOG_LEVEL=debug

# Public web/API URLs.
BURNLINK_PUBLIC_BASE_URL=http://localhost:5173
PUBLIC_BURNLINK_API_BASE_URL=http://localhost:8080
PUBLIC_BURNLINK_LOCAL_FILE_MAX_BYTES=1048560
BURNLINK_API_BASE_URL=http://localhost:8080
BURNLINK_INTERNAL_API_BASE_URL=http://localhost:8080
BURNLINK_API_ADDR=:8080

# Internal auth for worker -> api calls. Set a strong local value.
BURNLINK_INTERNAL_TOKEN=change-me-local

# NATS JetStream.
BURNLINK_NATS_URL=nats://127.0.0.1:4222
BURNLINK_NATS_STREAM=BURNLINK_JOBS
BURNLINK_NATS_JOB_SUBJECT=burnlink.jobs

# Local SQLite files.
BURNLINK_DATA_DIR=./var
BURNLINK_API_DB_PATH=./var/api.db
BURNLINK_WORKER_DB_PATH=./var/worker.db

# Storage thresholds.
BURNLINK_PAYLOAD_INLINE_MAX_BYTES=1048576
BURNLINK_MAX_FILE_BYTES=26214400
BURNLINK_DEFAULT_TTL_SECONDS=3600
BURNLINK_ALLOWED_TTL_SECONDS=600,3600,86400
BURNLINK_STORAGE_LARGE_BACKEND=disabled

# Worker.
BURNLINK_WORKER_ID=local-worker-1
BURNLINK_WORKER_CONCURRENCY=2

# OCI Object Storage. Used only when BURNLINK_STORAGE_LARGE_BACKEND=oci.
BURNLINK_OCI_AUTH_MODE=config_file
BURNLINK_OCI_CONFIG_FILE=
BURNLINK_OCI_PROFILE=DEFAULT
BURNLINK_OCI_REGION=
BURNLINK_OCI_NAMESPACE=
BURNLINK_OCI_BUCKET=
BURNLINK_OCI_COMPARTMENT_OCID=

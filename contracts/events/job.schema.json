{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flick.local/contracts/events/job.schema.json",
  "title": "Flick Job Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "kind", "requested_at"],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "delete_secret",
        "delete_oci_object"
      ]
    },
    "secret_id": {
      "type": "string",
      "minLength": 1
    },
    "object_key": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "enum": ["consumed", "expired", "orphan", "manual", "retry"]
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_context": {
      "type": "object",
      "description": "W3C trace-context (traceparent, optional tracestate) of the enqueuing span, for cross-process trace propagation. Telemetry IDs only.",
      "additionalProperties": { "type": "string" }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burnlink.local/contracts/credential-payload.schema.json",
  "title": "BurnLink Credential Payload",
  "description": "The JSON payload after the BLCR1: browser-only credential prefix. This is encrypted through the text-secret path and is not visible to the API.",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "type", "fields"],
  "properties": {
    "v": {
      "const": 1,
      "description": "Credential payload format version."
    },
    "type": {
      "type": "string",
      "enum": ["login", "card", "identity", "custom"]
    },
    "title": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/field"
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value", "secret"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "secret": {
          "type": "boolean",
          "description": "UI rendering hint for masking field values before encryption; not a server-enforced security boundary."
        }
      }
    }
  }
}
